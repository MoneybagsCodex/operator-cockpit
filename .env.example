# Chat backend: 'anthropic' (direct API) or 'bridge' (custom agent bridge)
CHAT_BACKEND=anthropic

# Required when CHAT_BACKEND=anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Path to shared state directory (default: ~/.operator-state)
# OPERATOR_STATE_DIR=~/.operator-state

# Bridge URL when CHAT_BACKEND=bridge
# COCKPIT_BRIDGE_URL=http://127.0.0.1:3001/send

# Optional API token -- protects all /api/* routes with a bearer token.
# When set, the same value must appear in NEXT_PUBLIC_API_TOKEN so the
# browser-side EventSource and fetch calls can authenticate.
# Leave both unset for local-only localhost access (CSRF protection still active).
# API_TOKEN=change-me-to-a-random-secret
# NEXT_PUBLIC_API_TOKEN=change-me-to-a-random-secret

# Jira sprint tickets widget
# Your Atlassian account email and an API token from https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_EMAIL=you@example.com
JIRA_TOKEN=your-jira-api-token-here
# JIRA_BASE_URL=https://your-domain.atlassian.net

# Bridge server (runs claude CLI subprocesses per agent)
BRIDGE_PORT=3002
COCKPIT_BRIDGE_URL=http://127.0.0.1:3002/send
CHAT_BACKEND=bridge
